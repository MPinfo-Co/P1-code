DATABASE_URL=postgresql://username:password@localhost:5432/mpbox
JWT_SECRET_KEY=your-secret-key
JWT_EXPIRE_MINUTES=60

# SSB
SSB_HOST=https://192.168.10.48
SSB_USERNAME=
SSB_PASSWORD=
SSB_LOGSPACE=ALL

# Anthropic
