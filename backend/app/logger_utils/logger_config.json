{
    "log_root": "../../logs",
    "rotation": "00:00",
    "retention": "1 month",
    "default_format": "{time:YYYY-MM-DD HH:mm:ss.SSS} | {level: <8} | {name}:{function}:{line} - {message}",
    "user_format": "{time:YYYY-MM-DD HH:mm:ss.SSS} | {level: <8} | user_id={extra[user_id]} | {message}",
    "channels": {
        "system": {
            "subdir": "system",
            "filename": "system.log",
            "level": "INFO"
        },
        "user": {
            "subdir": "user",
            "filename": "{time:YYYY-MM-DD}.log",
            "level": "INFO"
        },
        "service": {
            "subdir": "service",
            "filename": "service.log",
            "level": "INFO"
        }
    }
}
